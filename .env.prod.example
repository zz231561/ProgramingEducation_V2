# Self-host VPS 生產環境變數範本（roadmap 4-2a）
# 複製為 .env.prod 後填入實際值，**勿 commit**
# 用途：docker-compose.prod.yml + docker-compose.judge0.yml 的環境變數來源
#
# Zeabur 部署不用此檔案 — Zeabur 在 dashboard 設 env，敏感的標記為 Secret
# 對應 zeabur.json 的 ${VAR_NAME} 變數引用

# ===========================================================================
# 1. Application PostgreSQL（pgvector）
# ===========================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<強隨機密碼，至少 16 字元>
POSTGRES_DB=programing_education

# ===========================================================================
# 2. Auth — NextAuth.js v5 + Google OAuth
# ===========================================================================
# 產生方式：npx auth secret
AUTH_SECRET=<32+ 字元 random>

# Google Cloud Console → API & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=<xxx.apps.googleusercontent.com>
GOOGLE_CLIENT_SECRET=<Google OAuth Client Secret>

# 學生使用者實際看到的 URL（含 https）
WEB_URL=https://your-domain.com

# ===========================================================================
# 3. OpenAI（必要 — RAG / EDF Pipeline / 反思評分 / Comprehension）
# ===========================================================================
OPENAI_API_KEY=sk-proj-...

# 可選（有預設值）：
# LLM_MODEL=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-small

# ===========================================================================
# 4. Judge0
# ===========================================================================
# 選項 A：自架 Judge0（同 VPS，搭配 docker-compose.judge0.yml）
JUDGE0_API_URL=http://judge0-server:2358
JUDGE0_API_KEY=

# 選項 B：RapidAPI Judge0（50 次/天免費；註解上方兩行，啟用下方）
# JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_API_KEY=<RapidAPI Key>

# ===========================================================================
# 5. Judge0 自架專用密碼（僅選項 A 需要；對應 judge0.conf）
# ===========================================================================
# 兩個密碼必須與 judge0.conf 內 POSTGRES_PASSWORD / REDIS_PASSWORD **完全一致**
JUDGE0_POSTGRES_PASSWORD=<強隨機密碼>
JUDGE0_REDIS_PASSWORD=<強隨機密碼>

# ===========================================================================
# 6. 可選（debug / observability）
# ===========================================================================
# DEBUG=false
# LOG_LEVEL=INFO
# RATE_LIMIT_PER_MINUTE=10
