# === 資料庫 ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/programing_education

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Auth ===
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

# === OpenAI ===
OPENAI_API_KEY=sk-proj-...

# === Judge0 ===
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=xxx

# === 可選 ===
# DEBUG=false
# LOG_LEVEL=INFO
# 6-M 任務導向模型路由：LLM_MODEL = 預設（對話 + 分析組）；分組變數未設定時 fallback LLM_MODEL
# LLM_MODEL=gpt-5.4-mini
# LLM_MODEL_GENERATE=gpt-5-mini
# LLM_MODEL_VALIDATE=gpt-5.4
# LLM_MODEL_CONTENT=gpt-5.4
# EMBEDDING_MODEL=text-embedding-3-small
# RATE_LIMIT_PER_MINUTE=10

# === 開發者模式（生產環境必須保持關閉） ===
# DEV_MODE_ENABLED=false
# DEV_MODE_EMAILS=dev1@example.com,dev2@example.com
