  "segments": [
    {
      "start": 1.0,
      "end": 4.0,
      "text": "各位同學大家好,我是黃國豪老師"
    },
    {
      "start": 4.0,
      "end": 10.0,
      "text": "今天要介紹的單元是 C++ 程式的組成及語法規則"
    },
    {
      "start": 10.0,
      "end": 13.0,
      "text": "我們上一次所寫的第一個程式"
    },
    {
