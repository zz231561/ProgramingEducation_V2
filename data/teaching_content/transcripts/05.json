    },
    {
      "start": 218.0,
      "end": 221.0,
      "text": "這個稱之為 man 函式的本體"
    },
    {
      "start": 221.0,
      "end": 224.0,
      "text": "也就是放 man 函式的內容的地方"
    },
    {
      "start": 224.0,
      "end": 226.0,
      "text": "那特別要注意的是 man 函式"
    },
    {
      "start": 226.0,
      "end": 229.0,
      "text": "不一定要放在整個原始程式的開頭"
