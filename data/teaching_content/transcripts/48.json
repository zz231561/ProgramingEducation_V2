    {
      "start": 190.0,
      "end": 191.0,
      "text": "所以呢"
    },
    {
      "start": 191.0,
      "end": 193.0,
      "text": "我們最多可以輸入100"
    },
    {
      "start": 193.0,
      "end": 196.0,
      "text": "那我們假設這次是輸入人數是5"
    },
    {
      "start": 196.0,
      "end": 197.0,
