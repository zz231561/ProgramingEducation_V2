    {
      "start": 304.32000732421875,
      "end": 306.6000061035156,
      "text": "每個學生有兩個資料"
    },
    {
      "start": 306.6000061035156,
      "end": 310.1000061035156,
      "text": "這兩個資料分別是身高跟體重"
    },
    {
      "start": 310.5400085449219,
      "end": 313.29998779296875,
      "text": "那我們要記錄10個同學的身高體重"
    },
    {
      "start": 313.29998779296875,
      "end": 314.8999938964844,
      "text": "身高是公分 體重是公斤"
    },
    {
      "start": 314.8999938964844,
      "end": 315.94000244140625,
      "text": "然後來分析"
    },
    {
      "start": 315.9800109863281,
      "end": 318.17999267578125,
      "text": "每位同學的身材是過輕"
    },
    {
      "start": 318.17999267578125,
      "end": 320.2799987792969,
      "text": "還是健康 還是過重 還是肥胖"
    },
    {
      "start": 320.5799865722656,
      "end": 322.7799987792969,
      "text": "那我們會先輸入第一位同學的身高"
