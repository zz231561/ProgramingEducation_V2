    {
      "start": 322.7799987792969,
      "end": 324.4200134277344,
      "text": "這是公分 再來體重是公斤"
    },
    {
      "start": 324.4200134277344,
      "end": 325.9200134277344,
      "text": "就輸入都是整數"
