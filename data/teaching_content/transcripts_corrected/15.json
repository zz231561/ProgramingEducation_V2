  "segments": [
    {
      "start": 0.25999999046325684,
      "end": 1.7599999904632568,
      "text": "各位同學大家好"
    },
    {
      "start": 1.7599999904632568,
      "end": 3.1600000858306885,
      "text": "我是黃國豪老師"
    },
    {
      "start": 3.1600000858306885,
      "end": 4.559999942779541,
      "text": "今天要介紹的是"
    },
    {
      "start": 4.559999942779541,
      "end": 6.559999942779541,
      "text": "C++的第十五個單元"
    },
    {
      "start": 6.559999942779541,
      "end": 8.300000190734863,
      "text": "C++的四則運算"
    },
    {
      "start": 8.300000190734863,
      "end": 10.5600004196167,
      "text": "那什麼叫做運算式呢?"
    },
    {
      "start": 10.5600004196167,
      "end": 11.359999656677246,
      "text": "運算式呢"
    },
    {
      "start": 11.359999656677246,
      "end": 14.5600004196167,
      "text": "就是由運算子跟運算元所構成的"
    },
    {
      "start": 14.5600004196167,
      "end": 15.960000038146973,
      "text": "一個式子"
    },
    {
      "start": 15.960000038146973,
      "end": 19.559999465942383,
      "text": "那這個運算子指的就是運算的種類"
    },
    {
      "start": 19.559999465942383,
      "end": 20.760000228881836,
      "text": "加減乘除"
    },
    {
      "start": 20.760000228881836,
      "end": 22.459999084472656,
      "text": "這個叫做運算子"
    },
    {
      "start": 22.459999084472656,
      "end": 26.459999084472656,
      "text": "那運算元指的就是被處理的數字資料"
    },
    {
      "start": 26.459999084472656,
      "end": 29.559999465942383,
      "text": "例如無加十是一個運算式"
    },
    {
      "start": 29.6200008392334,
      "end": 31.6200008392334,
      "text": "那麼加就是一個運算子"
    },
    {
      "start": 31.6200008392334,
      "end": 33.119998931884766,
      "text": "那五跟十呢"
    },
    {
      "start": 33.119998931884766,
      "end": 34.119998931884766,
      "text": "就是運算元"
    },
    {
      "start": 34.119998931884766,
      "end": 36.619998931884766,
      "text": "那像加減乘除"
    },
    {
      "start": 36.619998931884766,
      "end": 38.119998931884766,
      "text": "這樣子的運算子"
    },
    {
      "start": 38.119998931884766,
      "end": 40.119998931884766,
      "text": "它需要兩個運算元"
    },
    {
      "start": 40.119998931884766,
      "end": 42.119998931884766,
      "text": "兩個數才能相加相減"
    },
    {
      "start": 42.119998931884766,
      "end": 43.119998931884766,
      "text": "相乘相除"
    },
    {
      "start": 43.119998931884766,
      "end": 45.619998931884766,
      "text": "所以我們把加減乘除這種運算子"
    },
    {
      "start": 45.619998931884766,
      "end": 47.619998931884766,
      "text": "稱為二元運算子"
    },
    {
      "start": 47.619998931884766,
      "end": 49.619998931884766,
      "text": "英文叫 Binary Operator"
    },
    {
      "start": 49.619998931884766,
      "end": 51.119998931884766,
      "text": "那有些運算子"
    },
    {
      "start": 51.119998931884766,
      "end": 53.119998931884766,
      "text": "其實只需要一個運算元"
    },
    {
      "start": 53.119998931884766,
      "end": 54.619998931884766,
      "text": "就可以計算了"
    },
    {
      "start": 54.619998931884766,
      "end": 56.119998931884766,
      "text": "比如說開根號"
    },
    {
      "start": 56.119998931884766,
      "end": 58.619998931884766,
      "text": "像這樣子的一種運算子"
    },
    {
      "start": 58.68000030517578,
      "end": 59.68000030517578,
      "text": "我們就稱之為"
    },
    {
      "start": 59.68000030517578,
      "end": 61.68000030517578,
      "text": "Unary Operator"
    },
    {
      "start": 61.68000030517578,
      "end": 63.18000030517578,
      "text": "那運算元"
    },
    {
      "start": 63.18000030517578,
      "end": 64.68000030517578,
      "text": "可以是字面常數"
    },
    {
      "start": 64.68000030517578,
      "end": 65.68000030517578,
      "text": "像五跟十"
    },
    {
      "start": 65.68000030517578,
      "end": 67.18000030517578,
      "text": "這個叫字面常數"
    },
    {
      "start": 67.18000030517578,
      "end": 68.18000030517578,
      "text": "也可以是變數"
    },
    {
      "start": 68.18000030517578,
      "end": 69.68000030517578,
      "text": "比如說X加Y"
    },
    {
      "start": 69.68000030517578,
      "end": 71.68000030517578,
      "text": "也可以是另外一個式子"
    },
    {
      "start": 71.68000030517578,
      "end": 73.68000030517578,
      "text": "比如說X加Y乘以Z"
    },
    {
      "start": 73.68000030517578,
      "end": 75.68000030517578,
      "text": "Y乘以Z當作一個運算元"
    },
    {
      "start": 75.68000030517578,
      "end": 76.68000030517578,
      "text": "加的運算元"
    },
    {
      "start": 76.68000030517578,
      "end": 77.68000030517578,
      "text": "也是可以的"
    },
    {
      "start": 77.68000030517578,
      "end": 79.68000030517578,
      "text": "那麼C++的四則運算規則"
    },
    {
      "start": 79.68000030517578,
      "end": 81.68000030517578,
      "text": "跟我們小時候所學的"
    },
    {
      "start": 81.68000030517578,
      "end": 84.18000030517578,
      "text": "先乘除後加減的規則是完全一樣的"
    },
    {
      "start": 84.18000030517578,
      "end": 86.68000030517578,
      "text": "但是有時候我們會希望能夠"
    },
    {
      "start": 86.68000030517578,
      "end": 87.68000030517578,
      "text": "自己來控制"
    },
    {
      "start": 87.73999786376953,
      "end": 89.73999786376953,
      "text": "要先乘還是先加"
    },
    {
      "start": 89.73999786376953,
      "end": 91.73999786376953,
      "text": "這時候我們可以用小括號"
    },
    {
      "start": 91.73999786376953,
      "end": 93.73999786376953,
      "text": "那跟小時候我們學的"
    },
    {
      "start": 93.73999786376953,
      "end": 95.73999786376953,
      "text": "小括號的概念也是一樣的"
    },
    {
      "start": 95.73999786376953,
      "end": 97.73999786376953,
      "text": "比較要注意的是"
    },
    {
      "start": 97.73999786376953,
      "end": 99.73999786376953,
      "text": "C++的四則運算有分整數"
    },
    {
      "start": 99.73999786376953,
      "end": 101.73999786376953,
      "text": "跟伏點數兩種"
    },
    {
      "start": 101.73999786376953,
      "end": 103.73999786376953,
      "text": "如果今天是"
    },
    {
      "start": 103.73999786376953,
      "end": 104.73999786376953,
      "text": "你希望計算的結果"
    },
    {
      "start": 104.73999786376953,
      "end": 105.73999786376953,
      "text": "要有小數點"
    },
    {
      "start": 105.73999786376953,
      "end": 107.73999786376953,
      "text": "那麼你的運算元"
    },
    {
      "start": 107.73999786376953,
      "end": 109.73999786376953,
      "text": "至少要有一個是伏點數的類型"
    },
    {
      "start": 109.73999786376953,
      "end": 111.73999786376953,
      "text": "double或者是Float"
    },
    {
      "start": 111.73999786376953,
      "end": 112.73999786376953,
      "text": "舉個例子"
    },
    {
      "start": 112.73999786376953,
      "end": 115.73999786376953,
      "text": "如果是6是整數"
    },
    {
      "start": 115.73999786376953,
      "end": 116.73999786376953,
      "text": "5是整數"
    },
    {
      "start": 116.80000305175781,
      "end": 118.80000305175781,
      "text": "結果這個相除會變成整數的除法"
    },
    {
      "start": 118.80000305175781,
      "end": 120.80000305175781,
      "text": "結果會是1而不是1.2"
    },
    {
      "start": 120.80000305175781,
      "end": 122.80000305175781,
      "text": "這原因是因為6跟5都是整數"
    },
    {
      "start": 122.80000305175781,
      "end": 124.80000305175781,
      "text": "它的結果就會是整數"
    },
    {
      "start": 124.80000305175781,
      "end": 126.80000305175781,
      "text": "所以它得到的是3"
    },
    {
      "start": 126.80000305175781,
      "end": 128.8000030517578,
      "text": "而不是真正的結果1.2倍"
    },
    {
      "start": 128.8000030517578,
      "end": 131.8000030517578,
      "text": "那如果你希望能夠求出1.2"
    },
    {
      "start": 131.8000030517578,
      "end": 133.8000030517578,
      "text": "那6跟5必須有一個數"
    },
    {
      "start": 133.8000030517578,
      "end": 136.8000030517578,
      "text": "至少有一個數是double或Float"
    },
    {
      "start": 136.8000030517578,
      "end": 138.8000030517578,
      "text": "那我們可以把它寫成6.0除以5"
    },
    {
      "start": 138.8000030517578,
      "end": 140.8000030517578,
      "text": "或者是6除以5.0"
    },
    {
      "start": 140.8000030517578,
      "end": 142.8000030517578,
      "text": "或者是6.0除以5.0"
    },
    {
      "start": 142.8000030517578,
      "end": 144.8000030517578,
      "text": "它就會求出1.2"
    },
    {
      "start": 144.86000061035156,
      "end": 146.86000061035156,
      "text": "這是因為C++會自動的"
    },
    {
      "start": 146.86000061035156,
      "end": 148.86000061035156,
      "text": "把另外一個數"
    },
    {
      "start": 148.86000061035156,
      "end": 149.86000061035156,
      "text": "也轉換成double"
    },
    {
      "start": 149.86000061035156,
      "end": 151.86000061035156,
      "text": "這樣才有辦法做一個"
    },
    {
      "start": 151.86000061035156,
      "end": 153.86000061035156,
      "text": "double的除法的運算"
    },
    {
      "start": 153.86000061035156,
      "end": 155.86000061035156,
      "text": "所以如果我們希望一個變數"
    },
    {
      "start": 155.86000061035156,
      "end": 157.86000061035156,
      "text": "它能計算出有小數點的數"
    },
    {
      "start": 157.86000061035156,
      "end": 159.86000061035156,
      "text": "那我們就必須用"
    },
    {
      "start": 159.86000061035156,
      "end": 161.86000061035156,
      "text": "double或Float來儲存這個變數"
    },
    {
      "start": 161.86000061035156,
      "end": 164.86000061035156,
      "text": "然後讓double或Float的變數"
    },
    {
      "start": 164.86000061035156,
      "end": 166.86000061035156,
      "text": "來當作我們的運算元"
    },
    {
      "start": 166.86000061035156,
      "end": 167.86000061035156,
      "text": "我們來看這個例子"
    },
    {
      "start": 167.86000061035156,
      "end": 169.86000061035156,
      "text": "15.cpp這個例子"
    },
    {
      "start": 169.86000061035156,
      "end": 171.86000061035156,
      "text": "這個例子是讓使用者"
    },
    {
      "start": 171.9199981689453,
      "end": 174.9199981689453,
      "text": "輸入A跟B兩個可以有小數點的數"
    },
    {
      "start": 174.9199981689453,
      "end": 176.9199981689453,
      "text": "然後再將這兩個數"
    },
    {
      "start": 176.9199981689453,
      "end": 178.9199981689453,
      "text": "進行加減乘除的四則運算"
    },
    {
      "start": 178.9199981689453,
      "end": 179.9199981689453,
      "text": "然後產生結果"
    },
    {
      "start": 179.9199981689453,
      "end": 181.9199981689453,
      "text": "那它的格式如下"
    },
    {
      "start": 181.9199981689453,
      "end": 182.9199981689453,
      "text": "請輸入A冒號"
    },
    {
      "start": 182.9199981689453,
      "end": 184.9199981689453,
      "text": "這時候我們使用者可以打一個"
    },
    {
      "start": 184.9199981689453,
      "end": 185.9199981689453,
      "text": "有小數點的數"
    },
    {
      "start": 185.9199981689453,
      "end": 187.9199981689453,
      "text": "然後接下來它會顯示"
    },
    {
      "start": 187.9199981689453,
      "end": 188.9199981689453,
      "text": "請輸入B冒號"
    },
    {
      "start": 188.9199981689453,
      "end": 190.9199981689453,
      "text": "我們可以打入第二個數"
    },
    {
      "start": 190.9199981689453,
      "end": 192.9199981689453,
      "text": "那這就是A這跟B"
    },
    {
      "start": 192.9199981689453,
      "end": 193.9199981689453,
      "text": "然後它會產生"
    },
    {
      "start": 193.9199981689453,
      "end": 195.9199981689453,
      "text": "A加B等於多少"
    },
    {
      "start": 195.9199981689453,
      "end": 196.9199981689453,
      "text": "A減B等於多少"
    },
    {
      "start": 196.9199981689453,
      "end": 197.9199981689453,
      "text": "A乘以B等於多少"
    },
    {
      "start": 197.9199981689453,
      "end": 199.9199981689453,
      "text": "A除以B等於多少"
    },
    {
      "start": 199.97999572753906,
      "end": 201.97999572753906,
      "text": "那這個的結果都可以包含小數"
    },
    {
      "start": 201.97999572753906,
      "end": 203.97999572753906,
      "text": "因為我們會用一個"
    },
    {
      "start": 203.97999572753906,
      "end": 205.97999572753906,
      "text": "double的變數來儲存這個A跟B"
    },
    {
      "start": 205.97999572753906,
      "end": 207.97999572753906,
      "text": "那程式碼就是這樣子"
    },
    {
      "start": 207.97999572753906,
      "end": 209.97999572753906,
      "text": "首先我們需要宣告"
    },
    {
      "start": 209.97999572753906,
      "end": 211.97999572753906,
      "text": "兩個變數分別是A跟B"
    },
    {
      "start": 211.97999572753906,
      "end": 213.97999572753906,
      "text": "然後我們讓使用者看到"
    },
    {
      "start": 213.97999572753906,
      "end": 214.97999572753906,
      "text": "請輸入A"
    },
    {
      "start": 214.97999572753906,
      "end": 216.97999572753906,
      "text": "然後使用者輸入的數就存到A"
    },
    {
      "start": 216.97999572753906,
      "end": 218.97999572753906,
      "text": "接下來使用者會看到"
    },
    {
      "start": 218.97999572753906,
      "end": 219.97999572753906,
      "text": "請輸入B"
    },
    {
      "start": 219.97999572753906,
      "end": 221.97999572753906,
      "text": "然後使用者可以輸入"
    },
    {
      "start": 221.97999572753906,
      "end": 223.97999572753906,
      "text": "一個數存到B"
    },
    {
      "start": 223.97999572753906,
      "end": 224.97999572753906,
      "text": "那A跟B因為都是double"
    },
    {
      "start": 224.97999572753906,
      "end": 226.97999572753906,
      "text": "所以它的運算就會含有小數"
    },
    {
      "start": 226.97999572753906,
      "end": 228.97999572753906,
      "text": "那我們接下來就是一個輸出的動作"
    },
    {
      "start": 229.0399932861328,
      "end": 231.0399932861328,
      "text": "用cout"
    },
    {
      "start": 231.0399932861328,
      "end": 233.0399932861328,
      "text": "我們要先輸出A的值"
    },
    {
      "start": 233.0399932861328,
      "end": 235.0399932861328,
      "text": "然後再串接一個加的符號"
    },
    {
      "start": 235.0399932861328,
      "end": 237.0399932861328,
      "text": "再串接B的值"
    },
    {
      "start": 237.0399932861328,
      "end": 239.0399932861328,
      "text": "再串接一個等號"
    },
    {
      "start": 239.0399932861328,
      "end": 241.0399932861328,
      "text": "再串接真正的A加B的結果"
    },
    {
      "start": 241.0399932861328,
      "end": 243.0399932861328,
      "text": "那最後一個換行"
    },
    {
      "start": 243.0399932861328,
      "end": 245.0399932861328,
      "text": "那加減乘除"
    },
    {
      "start": 245.0399932861328,
      "end": 247.0399932861328,
      "text": "其實我們可以複製這一行"
    },
    {
      "start": 247.0399932861328,
      "end": 249.0399932861328,
      "text": "產生另外的減跟乘跟除"
    },
    {
      "start": 249.0399932861328,
      "end": 251.0399932861328,
      "text": "只要把這個加變成減乘除"
    },
    {
      "start": 251.0399932861328,
      "end": 253.0399932861328,
      "text": "那這邊的運算也是一樣"
    },
    {
      "start": 253.0399932861328,
      "end": 255.0399932861328,
      "text": "變成減乘除"
    },
    {
      "start": 255.0399932861328,
      "end": 257.0400085449219,
      "text": "那這個程式就寫完了"
    },
    {
      "start": 257.1000061035156,
      "end": 259.1000061035156,
      "text": "那我們來看這個結果"
    },
    {
      "start": 259.1000061035156,
      "end": 261.1000061035156,
      "text": "當我們輸入1.5跟2"
    },
    {
      "start": 261.1000061035156,
      "end": 263.1000061035156,
      "text": "它就會求出加減乘除的結果"
    },
    {
      "start": 263.1000061035156,
      "end": 265.1000061035156,
      "text": "那接下來我們就實際的來操作看看"
    },
    {
      "start": 265.1000061035156,
      "end": 267.1000061035156,
      "text": "首先我們打開Dev C++"
    },
