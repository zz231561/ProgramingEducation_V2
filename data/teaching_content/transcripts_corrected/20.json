      "end": 17.0,
      "text": "位元 Bit 的集合"
    },
    {
      "start": 17.0,
      "end": 19.0,
      "text": "那麼它的運算方式就是"
    },
    {
      "start": 19.0,
      "end": 21.0,
      "text": "一個位元一個位元的處理"
    },
    {
      "start": 21.0,
      "end": 23.0,
      "text": "那位元運算子的運算源"
    },
    {
      "start": 23.0,
      "end": 27.0,
