# === Auth (NextAuth.js v5) ===
# 產生方式：npx auth secret
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# 生產環境（Zeabur / nginx 反代後）必須設 true
# NextAuth v5 預設不信任 X-Forwarded-Host，否則 callback URL 會用容器 internal hostname 而非公開 domain
# Dev 跑 localhost 時不需設（NextAuth 自動 trust localhost）
# AUTH_TRUST_HOST=true

# === Backend proxy ===
BACKEND_URL=http://localhost:8000
