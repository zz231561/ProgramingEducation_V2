{
  "$schema": "https://schema.zeabur.app/template.json",
  "services": [
    {
      "id": "web",
      "name": "web",
      "source": {
        "type": "GIT"
      },
      "template": "DOCKERFILE",
      "rootDirectory": "web",
      "domainKey": "WEB_DOMAIN",
      "ports": [3000],
      "env": {
        "AUTH_SECRET": {
          "value": "${AUTH_SECRET}"
        },
        "AUTH_GOOGLE_ID": {
          "value": "${AUTH_GOOGLE_ID}"
        },
        "AUTH_GOOGLE_SECRET": {
          "value": "${AUTH_GOOGLE_SECRET}"
        },
        "BACKEND_URL": {
          "value": "http://${BACKEND_HOST}:8000"
        }
      }
    },
    {
      "id": "backend",
      "name": "backend",
      "source": {
        "type": "GIT"
      },
      "template": "DOCKERFILE",
      "rootDirectory": "backend",
      "ports": [8000],
      "env": {
        "DATABASE_URL": {
          "value": "postgresql+asyncpg://${POSTGRES_USERNAME}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DATABASE}"
        },
        "REDIS_URL": {
          "value": "redis://${REDIS_HOST}:${REDIS_PORT}/0"
        },
        "NEXTAUTH_SECRET": {
          "value": "${AUTH_SECRET}"
        },
        "NEXTAUTH_URL": {
          "value": "https://${WEB_DOMAIN}"
        },
        "GOOGLE_CLIENT_ID": {
          "value": "${AUTH_GOOGLE_ID}"
        },
        "GOOGLE_CLIENT_SECRET": {
          "value": "${AUTH_GOOGLE_SECRET}"
        },
        "OPENAI_API_KEY": {
          "value": "${OPENAI_API_KEY}"
        },
        "JUDGE0_API_URL": {
          "value": "${JUDGE0_API_URL}"
        },
        "JUDGE0_API_KEY": {
          "value": "${JUDGE0_API_KEY}"
        }
      }
    },
    {
      "id": "postgres",
      "name": "postgres",
      "template": "PREBUILT",
      "spec": {
        "source": "MARKETPLACE",
        "id": "postgresql"
      }
    },
    {
      "id": "redis",
      "name": "redis",
      "template": "PREBUILT",
      "spec": {
        "source": "MARKETPLACE",
        "id": "redis"
      }
    }
  ]
}
